rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /tracks/{uid}/{trackId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 200 * 1024 * 1024
        && (request.resource.contentType == 'audio/mpeg'
            || request.resource.contentType == 'audio/wav'
            || request.resource.contentType == 'audio/x-wav');
    }
  }
}
